{
  "name": "ecomdash",
  "version": "1.0.0",
  "description": "Dashboard de rentabilidad para ecommerce",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "db:setup": "node server/db/setup.js",
    "db:seed": "node server/db/seed.js",
    "db:reset": "node server/db/reset.js",
    "db:fresh": "node -e \"require('fs').existsSync('server/db/ecomdash.db') && require('fs').unlinkSync('server/db/ecomdash.db')\" && node server/db/setup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
